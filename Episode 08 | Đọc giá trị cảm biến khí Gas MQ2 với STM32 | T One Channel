/* USER CODE BEGIN 4 */
void HAL_ADC_ConvCpltCallback(ADC_HandleTypeDef* hadc)
{
    if(hadc->Instance == ADC1)
    {
        process_gas_sensor();
    }
}

uint32_t adc_average()
{
    uint32_t sum = 0;

    for(int i=0;i<ADC_BUFFER_SIZE;i++)
    {
        sum += adc_buffer[i];
    }

    return sum / ADC_BUFFER_SIZE;
}

float get_voltage(uint32_t adc)
{
	float v_adc = adc * 3.3 / 4095.0;
	float v_out = v_adc * (R1 + R2) / R2;
	return v_out;
}

float get_Rs(float vout)
{
	if(vout <= 0.001){
		return 0;
	}

	return RL * (VCC - vout) / vout;
}

float get_ppm(float Rs)
{
	 if(R0 <= 0){
		 return 0;
	 }

	float ratio = Rs / R0;
	return 574.25 * pow(ratio, -2.222);
}

float Calib_R0(){
	uint32_t adc;
	float voltage;
	float Rs;

	adc = adc_average();

	voltage = get_voltage(adc);

	Rs = get_Rs(voltage);

	return Rs/9.83;
}

void process_gas_sensor()
{

    uint32_t adc;
    float voltage;
    float Rs;
    float ppm;

    adc = adc_average();

    voltage = get_voltage(adc);

    Rs = get_Rs(voltage);

    if(sensor_ready == 0)
    {
        return;   // chưa đủ 24h thì bỏ qua
    }

    ppm = get_ppm(Rs);

    (void)ppm;
}
